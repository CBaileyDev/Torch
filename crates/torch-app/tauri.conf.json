{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Torch",
  "version": "0.1.0",
  "identifier": "app.torch.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../ui/dist",
    "beforeDevCommand": "echo 'Vite dev server can be started separately with: cd ui && npm run dev (for browser demo mode)'",
    "beforeBuildCommand": "npm run build --prefix ../../ui"
  },
  "app": {
    "windows": [],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}